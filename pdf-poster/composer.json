    }
  ],
  "require": {
    "freemius/wordpress-sdk": "^2.12",
    "composer/installers": "^2.3",
    "oomphinc/composer-installers-extender": "^2.0"
  },
  "repositories": [],
  "config": {
    "allow-plugins": {
